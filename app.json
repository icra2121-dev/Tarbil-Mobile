{
  "expo": {
    "name": "KOBÜDS 4.0",
    "slug": "tarbil-mobile",
    "version": "5.2.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png",
        "backgroundColor": "#000000"
      },
      "package": "com.tarbil.ai",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAUPQ3speFzL-5TZRJ5ubkelTYIQ2usmbA"
        }
      },
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "NOTIFICATIONS",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-location",
      "expo-notifications",
      "expo-image",
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "integrations": {
        "gatewayUrlEnv": "EXPO_PUBLIC_INTEGRATION_API_URL",
        "institutionalEmailDomainEnv": "EXPO_PUBLIC_INSTITUTIONAL_EMAIL_DOMAIN",
        "secretOwner": "KOBÜKS ve CBS API anahtarları mobil pakete değil güvenli kurumsal arka uca konulmalıdır."
      },
      "eas": {
        "projectId": "932d5a9a-9a20-4bcf-98e0-f999cf3a2e4b"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "owner": "maximus021"
  }
}